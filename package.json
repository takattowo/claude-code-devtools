{
  "name": "cli-talker",
  "version": "0.0.1",
  "private": true,
  "description": "Agent DevTools for Claude Code",
  "license": "MIT",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "build": "pnpm -r --filter @cli-talker/core --filter @cli-talker/adapter-claude-code --filter @cli-talker/server build && pnpm --filter @cli-talker/web build && pnpm --filter claude-code-devtools build",
    "test": "pnpm -r --stream test",
    "lint": "eslint . --ext .js,.cjs,.ts,.tsx",
    "typecheck": "pnpm -r --stream typecheck",
    "dev": "pnpm --filter claude-code-devtools dev"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "prettier": "^3.2.0"
  }
}
